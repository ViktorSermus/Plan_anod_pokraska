# Скопируйте в secrets.toml (не коммитьте secrets.toml в git).
# Streamlit Cloud: те же ключи в разделе Secrets приложения.

DATABASE_URL = "postgresql://postgres:ПАРОЛЬ@db.xxxxx.supabase.co:5432/postgres?sslmode=require"

# Регион проекта (Supabase → Project Settings → General → Region), напр. eu-central-1.
# Нужен для Streamlit Cloud / сетей без IPv6: приложение подключится через Session pooler (IPv4).
# Либо вместо этого укажите в DATABASE_URL строку «Session pooler» из Connect — тогда ключ не нужен.
# SUPABASE_POOLER_REGION = "eu-central-1"

SUPABASE_URL = "https://xxxxx.supabase.co"
SUPABASE_ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Полный публичный URL приложения (для возврата после Google OAuth).
# Локально: http://localhost:8501
# Streamlit Cloud: https://ВАШ-ПРИЛОЖЕНИЕ.streamlit.app
APP_BASE_URL = "http://localhost:8501"

# Опционально: true/false — архивировать строки, отсутствующие в новом импорте (по умолчанию true).
# ARCHIVE_MISSING_AS_INACTIVE = true
